@page "/"
@layout EmptyLayout
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>CompVault - Logg inn</PageTitle>

<MudPaper Elevation="0" Class="pa-10 rounded-2xl glass-card login-container login-paper">
    <div class="d-flex flex-column align-center mb-8">
        <div class="logo-pulse mb-4">
            <img src="CompVault.png" alt="CompVault Logo" Class="logo-img" />
        </div>
        <MudText Typo="Typo.h3" Class="mb-1 title-text">CompVault</MudText>
        <MudText Typo="Typo.body1" Class="subtitle-text">
            Kompetanse- og HMS-portal
        </MudText>
    </div>

    @if (!_otpSent)
    {
        <div class="step-transition">
            <MudText Typo="Typo.h6" Class="mb-1 step-title">Velkommen tilbake</MudText>
            <MudText Typo="Typo.body2" Class="mb-5 step-subtitle">Skriv inn e-postadressen din for å fortsette</MudText>

            <MudTextField @bind-Value="_email"
                          @ref="_emailField"
                          Label="E-postadresse"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          AdornmentColor="Color.Primary"
                          Immediate="true"
                          Class="mb-5 input-field text-field-rounded"
                          OnKeyDown="@((e) => { if(e.Key == "Enter") _ = SubmitEmailAsync(); })" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="SubmitEmailAsync"
                       Disabled="_isLoading || string.IsNullOrWhiteSpace(_email)"
                       Class="primary-button py-3">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="loading-spinner" />
                    <span>Sender kode...</span>
                }
                else
                {
                    <span>Fortsett</span>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="ml-2" />
                }
            </MudButton>
        </div>

        <MudAlert Severity="Severity.Info"
                  Class="mt-8 demo-alert"
                  Dense="true"
                  Variant="Variant.Outlined">
            <MudText Typo="Typo.caption">
                <strong>Demo:</strong> Bruk <code Class="demo-code">test@compvault.no</code>
            </MudText>
        </MudAlert>
    }
    else
    {
        <div class="step-transition">
            <MudButton Variant="Variant.Text"
                       Size="Size.Small"
                       OnClick="GoBackToEmail"
                       Disabled="_isLoading"
                       Class="mb-4 back-button px-2"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Tilbake
            </MudButton>

            <MudText Typo="Typo.h6" Class="mb-1 step-title">Verifiser koden</MudText>
            <MudText Typo="Typo.body2" Class="mb-5 step-subtitle">
                Vi sendte en 6-sifret kode til <span Class="email-highlight">@_email</span>
            </MudText>

            <MudTextField @bind-Value="_otpCode"
                          @ref="_otpField"
                          Label="Engangskode"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Number"
                          MaxLength="6"
                          Immediate="true"
                          Class="mb-5 otp-input text-field-rounded"
                          OnKeyDown="@((e) => { if(e.Key == "Enter") _ = SubmitOtpAsync(); })" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="SubmitOtpAsync"
                       Disabled="_isLoading || string.IsNullOrWhiteSpace(_otpCode)"
                       Class="primary-button py-3">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="loading-spinner" />
                    <span>Logger inn...</span>
                }
                else
                {
                    <span>Logg inn</span>
                    <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Small" Class="ml-2" />
                }
            </MudButton>

            <div class="d-flex justify-center mt-4">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="ResendCode"
                           Disabled="_isLoading || _resendTimer > 0"
                           Class="resend-button">
                    @if (_resendTimer > 0)
                    {
                        <span>Send på nytt om @_resendTimer s</span>
                    }
                    else
                    {
                        <span>Ikke mottatt koden?</span>
                    }
                </MudButton>
            </div>
        </div>

        <MudAlert Severity="Severity.Info"
                  Class="mt-6 demo-alert"
                  Dense="true"
                  Variant="Variant.Outlined">
            <MudText Typo="Typo.caption">
                <strong>Demo:</strong> Koden er <code Class="demo-code">123456</code>
            </MudText>
        </MudAlert>
    }
</MudPaper>

@code {
    private string _email = string.Empty;
    private string _otpCode = string.Empty;
    private bool _otpSent;
    private bool _isLoading;
    private int _resendTimer;

    private MudTextField<string> _emailField = null!;
    private MudTextField<string> _otpField = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _emailField.FocusAsync();
        }
    }

    private string? ValidateEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return "E-post er påkrevd";
        if (!email.Contains("@") || !email.Contains("."))
            return "Ugyldig e-postadresse";
        return null;
    }

    private string? ValidateOtp(string otp)
    {
        if (string.IsNullOrWhiteSpace(otp))
            return "Engangskode er påkrevd";
        if (otp.Length != 6)
            return "Koden må være 6 siffer";
        if (!System.Text.RegularExpressions.Regex.IsMatch(otp, "^[0-9]{6}$"))
            return "Koden må kun inneholde tall";
        return null;
    }

    private async Task SubmitEmailAsync()
    {
        var validation = ValidateEmail(_email);
        if (validation != null)
        {
            Snackbar.Add(validation, Severity.Warning);
            return;
        }

        _isLoading = true;

        var request = new RequestOtpRequest
        {
            Email = _email,
            DeliveryMethod = OtpDeliveryMethod.Email
        };

        var result = await AuthService.RequestOtpAsync(request, CancellationToken.None);

        if (result.IsSuccess)
        {
            _otpSent = true;
            Snackbar.Add("Engangskode sendt! (Sjekk demo-info)", Severity.Success);
            // Fokus på OTP-feltet etter render
            _ = Task.Run(async () =>
            {
                await Task.Delay(100);
                await InvokeAsync(async () => await _otpField.FocusAsync());
            });
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Kunne ikke sende kode", Severity.Error);
        }

        _isLoading = false;
    }

    private async Task SubmitOtpAsync()
    {
        var validation = ValidateOtp(_otpCode);
        if (validation != null)
        {
            Snackbar.Add(validation, Severity.Warning);
            return;
        }

        _isLoading = true;

        var request = new VerifyOtpRequest
        {
            Email = _email,
            OtpCode = _otpCode
        };

        var result = await AuthService.VerifyOtpAsync(request, CancellationToken.None);

        if (result.IsSuccess)
        {
            Snackbar.Add("Velkommen tilbake!", Severity.Success);
            NavigationManager.NavigateTo("/dashboard");
        }
        else
        {
            Snackbar.Add(result.Error?.Message ?? "Ugyldig kode", Severity.Error);
        }

        _isLoading = false;
    }

    private void GoBackToEmail()
    {
        _otpSent = false;
        _otpCode = string.Empty;
        _resendTimer = 0;
        _ = Task.Run(async () =>
        {
            await Task.Delay(100);
            await InvokeAsync(async () => await _emailField.FocusAsync());
        });
    }

    private async Task ResendCode()
    {
        if (_resendTimer > 0) return;

        _resendTimer = 30;
        _ = Task.Run(async () =>
        {
            while (_resendTimer > 0)
            {
                await Task.Delay(1000);
                _resendTimer--;
                await InvokeAsync(StateHasChanged);
            }
        });

        // Send koden på nytt
        var request = new RequestOtpRequest
        {
            Email = _email,
            DeliveryMethod = OtpDeliveryMethod.Email
        };

        var result = await AuthService.RequestOtpAsync(request, CancellationToken.None);

        if (result.IsSuccess)
        {
            Snackbar.Add("Ny kode sendt!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Kunne ikke sende kode", Severity.Error);
        }
    }
}
