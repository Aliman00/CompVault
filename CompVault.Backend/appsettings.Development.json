{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=compvault_db;Username=compvault_user;Password=compvault_dev_pass"
  },
  "JwtSettings": {
    "Secret": "DEV_ONLY_SECRET_CHANGE_BEFORE_PRODUCTION_32CHARS!",
    "Issuer": "CompVault",
    "Audience": "CompVault.Clients",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  }
}