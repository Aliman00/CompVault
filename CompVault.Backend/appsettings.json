{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=compvault_db;Username=compvault_user;Password=compvault_dev_pass"
  },
  "JwtSettings": {
    "Secret": "CHANGE_ME_USE_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "CompVault",
    "Audience": "CompVault.Clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  }
}